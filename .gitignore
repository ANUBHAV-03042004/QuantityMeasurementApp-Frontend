# ── .gitignore ignores itself? No — .gitignore should always be committed ──
# This file IS tracked by git intentionally.

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm/
.yarn/

# ── Angular build output ──────────────────────────────────────────────────────
dist/
.angular/
.angular/cache/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
environment.ts
src/environments/environment.prod.ts
src/environments/environment.local.ts

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
.project
.classpath
.settings/
